{% extends "comment.j2" %}
{% block content %}

syntax = proto{{version if version else '3'}};

{% if package %}package {{ package_name }};{% endif %}

{% block options %}
    {% for key, val in (options or {}).items() %}
    option {{ (key, val) | format_option }};
    {% endfor %}
{% endblock %}

{% block blocks %}
  {% for block in blocks %}
  {{block}}
  {% endfor %}
{% endblock %}


{% endblock %}